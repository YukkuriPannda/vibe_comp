	(symbol (lib_id "Connector_Audio:AudioJack3") (at 20.32 90.17 0) (unit 1)
		(exclude_from_sim no)(in_bom yes)(on_board yes)(dnp no)(fields_autoplaced yes)
		(uuid "0717f323-6f06-4737-b457-9d54fa9c5623")
		(property "Reference" "J1" (at 22.32 84.17 0) (effects (font (size 1.27 1.27))))
		(property "Value" "6.3mm TRS(mono use)" (at 22.32 96.17 0) (effects (font (size 1.27 1.27))))
		(property "Footprint" "Connector_Audio:Jack_6.35mm_CUI-SameSky_SJ-63053A_Horizontal" (at 20.32 90.17 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(property "Datasheet" "https://www.sameskydevices.com/product/resource/sj-63053a.pdf" (at 20.32 90.17 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(property "Notes" "6.3mmフォンジャック。判断: リング接点(R)を電池(-)の帰路として使用し、モノラルTSプラグのスリーブがリング-スリーブ間を物理的に橋絡した時のみ電池が通電するバッテリーセーブ回路として解釈(標準的なDIYストンプボックス電池スイッチ手法)。2026-07-02: 調達部品をNeutrik NRJ6HFからCUI/Same Sky SJ-63053A(6.35mm横型TRSジャック、スイッチ接点なし、through-hole/right-angle/threaded with nut)に変更したためfootprintも新規作成し差し替え(信号3ピンT/R/S、ピッチ5.00mm、ドリルø1.00mm(+0.2/-0)、位置決め用非導通ペグ穴ø2.20mm(+0.2/-0)×2)。旧NRJ6HF footprintにあったTN/RN/SNのスイッチ接点パッドはSJ-63053Aには存在しないためfootprintから削除(元々ネット未接続だったため回路的な矛盾なし)。注意: SJ-63053AはDigiKey在庫578個のみのDiscontinued(生産完了)品(2026-07-01時点確認)。本基板1台分の製作には支障ないが、将来の追加生産時は代替品の選定が必要。また3DモデルはSame Sky公式サイト・SnapEDAとも入手できなかったため footprint 側の3Dモデル参照は未設定。ペグ穴の正確な位置はデータシートの寸法図(ベクター図)から完全には一意に特定できなかったため、電気的に重要な信号3ピンの座標(5.00mmピッチ・ø1.00mm)を優先して確定し、ペグ穴位置は妥当な工学的推定値。実装前に現物合わせでの確認を推奨。" (at 20.32 90.17 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(pin "T" (uuid "50baed84-423d-48cd-9758-3fc949247f10"))
		(pin "S" (uuid "7c08aadc-9c83-47bc-b23d-fb0b920f6587"))
		(pin "R" (uuid "3da1cad5-de9f-4970-a07d-6955630f0dc7"))
	)
