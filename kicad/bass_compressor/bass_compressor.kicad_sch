	(symbol (lib_id "Relay:Relay_DPDT") (at 279.4 260.35 0) (unit 1)
		(exclude_from_sim no)(in_bom yes)(on_board yes)(dnp no)(fields_autoplaced yes)
		(uuid "61512f5c-0de2-42bd-85ca-6de5920e64bc")
		(property "Reference" "RL1" (at 281.4 254.35 0) (effects (font (size 1.27 1.27))))
		(property "Value" "941H-2C-5D" (at 281.4 266.35 0) (effects (font (size 1.27 1.27))))
		(property "Footprint" "Relay_THT:Relay_DPDT_HsinDa_941H-2C-5D" (at 279.4 260.35 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(property "Datasheet" "https://akizukidenshi.com/goodsaffix/941H-2C-5D.pdf" (at 279.4 260.35 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(property "Notes" "941H-2C-5D (秋月, 5V DPDT)。circuit_reference.md改訂(2026-07-01)によりDPDT両極を使用する真のトゥルーバイパス構成に変更。Pole1(入力切替): 11=COM(J1後段入力信号 IN_SIGNAL), 12=NC接点→DRY(バイパス直通ノード), 14=NO接点→WET_IN(C_inへ、コンプレッサー回路入力)。Pole2(出力切替): 21=COM(J2への出力信号 OUT_SIGNAL), 22=NC接点→DRY(Pole1のNCと共通、バイパス直通ノード), 24=NO接点→WET_OUT(C5後段、コンプレッサー回路出力)。非励磁(バイパス)時は入力→12→DRY→22→出力のみが導通し、励磁時は入力→14→WET_IN→(コンプレッサー回路)→WET_OUT→24→出力のみが導通する真のトゥルーバイパス。footprint: 2026-07-02にHSINDA公式データシート(941H-2C-5D.pdf p.18 Drilling Plan/Internal Connections)を確認し、footprintをRelay_DPDT_Schrack-RT2-FormC_RM5mm(列ピッチ15.26/20.30/25.34mm・行7.5mm・ドリル1.3mmで実物と不一致)から実寸に合わせて修正(物理ピン1/16=コイルA1/A2、4/13=12/22(NC,DRY)、6/11=11/21(COM)、8/9=14/24(NO・WET)、列ピッチ7.62/12.70/17.78mm、行7.62mm、ドリル0.8mm)。KiCad標準ライブラリに完全一致するfootprintは無かったため、既存footprintを直接編集する形で対応(footprint名はRelay_DPDT_HsinDa_941H-2C-5Dにリネームしたローカル定義)。" (at 279.4 260.35 0) (effects (font (size 1.27 1.27)) (hide yes)))
		(pin "A1" (uuid "7ed712ea-2b29-48d5-9326-72961c5b2a69"))
		(pin "A2" (uuid "59235e0f-dfac-4ce6-878c-c7ac92d20291"))
		(pin "11" (uuid "9dac0b4e-3bd2-4f6b-9fbe-d4442bf3a386"))
		(pin "12" (uuid "bba5e449-b8c3-44e3-88da-a39c7e82dd08"))
		(pin "14" (uuid "f5643ed9-524d-4022-9243-a871bc9fbf1f"))
		(pin "21" (uuid "00193c1c-b845-4bcd-af58-5bca689c71ec"))
		(pin "22" (uuid "dfc284d5-d8cf-48a0-a95a-8e05437990a4"))
